{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cacic-eventos/shared-data-types": ["shared-data-types/src/index.ts"],
      "@cacic-eventos/shared-utils": ["shared-utils/src/index.ts"],
      "@cacic-eventos/shared-frontend-types": [
        "shared-data-types/src/lib/frontend-types.ts"
      ],
      "@cacic-eventos/shared-angular": ["shared-angular/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
